{
  "typescript.tsdk": "node_modules/typescript/lib",
  "typescript.enablePromptUseWorkspaceTsdk": true,
  "debug.onTaskErrors": "showErrors",
  "files.exclude": {
    "out": false
  },
  "search.exclude": {
    "out": true,
    "node_modules": true
  },

  "workbench.colorTheme": "Default Dark Modern",
  "window.titleBarStyle": "custom",

  "projectColors.name": "TaskKeeper",
  "projectColors.mainColor": "#059669",
  "projectColors.isTitleBarColored": true,
  "projectColors.isActivityBarColored": true,
  "projectColors.isStatusBarColored": true,
  "projectColors.isProjectNameColored": true,
  "projectColors.isActiveItemsColored": true,
  "projectColors.setWindowTitle": true,

  "workbench.colorCustomizations": {
    "titleBar.activeBackground": "#059669",
    "titleBar.activeForeground": "#ffffff",
    "titleBar.inactiveBackground": "#059669",
    "titleBar.inactiveForeground": "#ffffff90",
    "statusBarItem.warningBackground": "#059669",
    "statusBarItem.warningForeground": "#ffffff",
    "statusBarItem.warningHoverBackground": "#059669",
    "statusBarItem.warningHoverForeground": "#ffffff90",
    "statusBarItem.remoteBackground": "#12a376",
    "statusBarItem.remoteForeground": "#ffffff",
    "statusBarItem.remoteHoverBackground": "#1fb083",
    "statusBarItem.remoteHoverForeground": "#ffffff90",
    "statusBar.background": "#059669",
    "statusBar.foreground": "#ffffff",
    "statusBar.border": "#059669",
    "statusBar.debuggingBackground": "#059669",
    "statusBar.debuggingForeground": "#ffffff",
    "statusBar.debuggingBorder": "#059669",
    "statusBar.noFolderBackground": "#059669",
    "statusBar.noFolderForeground": "#ffffff",
    "statusBar.noFolderBorder": "#059669",
    "statusBar.prominentBackground": "#059669",
    "statusBar.prominentForeground": "#ffffff",
    "statusBar.prominentHoverBackground": "#059669",
    "statusBar.prominentHoverForeground": "#ffffff90",
    "focusBorder": "#05966999",
    "progressBar.background": "#059669",
    "textLink.foreground": "#45d6a9",
    "textLink.activeForeground": "#52e3b6",
    "selection.background": "#00895c",
    "list.highlightForeground": "#059669",
    "list.focusAndSelectionOutline": "#05966999",
    "button.background": "#059669",
    "button.foreground": "#ffffff",
    "button.hoverBackground": "#12a376",
    "tab.activeBorderTop": "#12a376",
    "pickerGroup.foreground": "#12a376",
    "list.activeSelectionBackground": "#0596694d",
    "panelTitle.activeBorder": "#12a376",
    "activityBar.background": "#059669",
    "activityBar.foreground": "#ffffff",
    "activityBar.activeBorder": "#059669",
    "activityBar.inactiveForeground": "#ffffff90",
    "activityBarBadge.foreground": "#ffffff",
    "activityBarBadge.background": "#059669"
  },
  "window.title": "TaskKeeper"
}
