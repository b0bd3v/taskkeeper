{
  "name": "taskkeeper",
  "displayName": "TaskKeeper",
  "description": "Task context switching for support developers — patches, breakpoints, and bookmarks per ticket.",
  "version": "0.0.1",
  "publisher": "utils",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=20"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:taskkeeper.tasks",
    "onCommand:taskkeeper.createTask",
    "onCommand:taskkeeper.switchTask",
    "onCommand:taskkeeper.refreshTasks",
    "onCommand:taskkeeper.selectTaskFromTree"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "taskkeeper.createTask",
        "title": "Create Task",
        "category": "TaskKeeper",
        "icon": "$(add)"
      },
      {
        "command": "taskkeeper.switchTask",
        "title": "Switch Task",
        "category": "TaskKeeper",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "taskkeeper.refreshTasks",
        "title": "Refresh",
        "category": "TaskKeeper",
        "icon": "$(refresh)"
      },
      {
        "command": "taskkeeper.selectTaskFromTree",
        "title": "Select Task",
        "category": "TaskKeeper"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "taskkeeper",
          "title": "TaskKeeper",
          "icon": "$(checklist)"
        }
      ]
    },
    "views": {
      "taskkeeper": [
        {
          "id": "taskkeeper.tasks",
          "name": "Tasks"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "taskkeeper.createTask",
          "when": "view == taskkeeper.tasks",
          "group": "navigation@1"
        },
        {
          "command": "taskkeeper.switchTask",
          "when": "view == taskkeeper.tasks",
          "group": "navigation@2"
        },
        {
          "command": "taskkeeper.refreshTasks",
          "when": "view == taskkeeper.tasks",
          "group": "navigation@3"
        }
      ],
      "commandPalette": [
        {
          "command": "taskkeeper.selectTaskFromTree",
          "when": "false"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.1",
    "typescript": "^5.5.0"
  }
}
