{
  "name": "taskkeeper",
  "displayName": "TaskKeeper",
  "description": "Task context switching for support developers — patches, breakpoints, and bookmarks per ticket.",
  "version": "0.0.1",
  "publisher": "utils",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=20"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:taskkeeper.tasks",
    "onCommand:taskkeeper.createTask",
    "onCommand:taskkeeper.switchTask",
    "onCommand:taskkeeper.refreshTasks",
    "onCommand:taskkeeper.selectTaskFromTree",
    "onCommand:taskkeeper.activateTaskConfirm",
    "onCommand:taskkeeper.activateGeneral",
    "onCommand:taskkeeper.renameTask",
    "onCommand:taskkeeper.deleteTask",
    "onCommand:taskkeeper.completeTask"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "taskkeeper.createTask",
        "title": "Create Task",
        "category": "TaskKeeper",
        "icon": "$(add)"
      },
      {
        "command": "taskkeeper.switchTask",
        "title": "Switch Task",
        "category": "TaskKeeper",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "taskkeeper.refreshTasks",
        "title": "Refresh",
        "category": "TaskKeeper",
        "icon": "$(refresh)"
      },
      {
        "command": "taskkeeper.selectTaskFromTree",
        "title": "Select Task",
        "category": "TaskKeeper"
      },
      {
        "command": "taskkeeper.activateGeneral",
        "title": "Activate General Scope",
        "category": "TaskKeeper",
        "icon": "$(home)"
      },
      {
        "command": "taskkeeper.activateTaskConfirm",
        "title": "Activate Task",
        "category": "TaskKeeper",
        "icon": "$(play)"
      },
      {
        "command": "taskkeeper.renameTask",
        "title": "Rename Task",
        "category": "TaskKeeper",
        "icon": "$(edit)"
      },
      {
        "command": "taskkeeper.deleteTask",
        "title": "Delete Task",
        "category": "TaskKeeper",
        "icon": "$(trash)"
      },
      {
        "command": "taskkeeper.completeTask",
        "title": "Mark Task as Completed",
        "category": "TaskKeeper",
        "icon": "$(check-all)"
      },
      {
        "command": "taskkeeper.openChangeFile",
        "title": "Open Change File",
        "category": "TaskKeeper"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "taskkeeper",
          "title": "TaskKeeper",
          "icon": "$(checklist)"
        }
      ]
    },
    "views": {
      "taskkeeper": [
        {
          "id": "taskkeeper.tasks",
          "name": "Tasks"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "taskkeeper.createTask",
          "when": "view == taskkeeper.tasks",
          "group": "navigation@1"
        },
        {
          "command": "taskkeeper.switchTask",
          "when": "view == taskkeeper.tasks",
          "group": "navigation@2"
        },
        {
          "command": "taskkeeper.refreshTasks",
          "when": "view == taskkeeper.tasks",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "taskkeeper.activateTaskConfirm",
          "when": "view == taskkeeper.tasks && viewItem == taskkeeper.general",
          "group": "inline@1"
        },
        {
          "command": "taskkeeper.activateTaskConfirm",
          "when": "view == taskkeeper.tasks && viewItem == taskkeeper.general",
          "group": "1_activate@1"
        },
        {
          "command": "taskkeeper.activateTaskConfirm",
          "when": "view == taskkeeper.tasks && viewItem =~ /^taskkeeper\\.task($|\\.archived$)/",
          "group": "inline@1"
        },
        {
          "command": "taskkeeper.activateTaskConfirm",
          "when": "view == taskkeeper.tasks && viewItem =~ /^taskkeeper\\.task($|\\.archived$)/",
          "group": "1_activate@1"
        },
        {
          "command": "taskkeeper.renameTask",
          "when": "view == taskkeeper.tasks && viewItem =~ /^taskkeeper\\.task/",
          "group": "2_modify@1"
        },
        {
          "command": "taskkeeper.completeTask",
          "when": "view == taskkeeper.tasks && viewItem =~ /^taskkeeper\\.task($|\\.active$)/",
          "group": "2_modify@2"
        },
        {
          "command": "taskkeeper.deleteTask",
          "when": "view == taskkeeper.tasks && viewItem =~ /^taskkeeper\\.task/",
          "group": "3_danger@1"
        }
      ],
      "commandPalette": [
        {
          "command": "taskkeeper.selectTaskFromTree",
          "when": "false"
        },
        {
          "command": "taskkeeper.activateTaskConfirm",
          "when": "false"
        },
        {
          "command": "taskkeeper.renameTask",
          "when": "false"
        },
        {
          "command": "taskkeeper.deleteTask",
          "when": "false"
        },
        {
          "command": "taskkeeper.completeTask",
          "when": "false"
        },
        {
          "command": "taskkeeper.openChangeFile",
          "when": "false"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "tsc -p tsconfig.test.json && node --require ./out-test/tests/helpers/installVscodeMock.js --test out-test/tests/",
    "test:coverage": "tsc -p tsconfig.test.json && c8 --reporter=text --reporter=lcov --include='out-test/src/**/*.js' --exclude='out-test/tests/**' node --require ./out-test/tests/helpers/installVscodeMock.js --test out-test/tests/",
    "test:watch": "tsc -p tsconfig.test.json -w",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.1",
    "c8": "^10.1.3",
    "typescript": "^5.5.0"
  }
}
